{
    "$schema": "https://fundingjson.org/schema/v1.1.0.json",

    "version": "v1.1.0",

    "entity": {
        "type": "organisation", 
        "role": "steward",
        "name": "Odoo Community Association (OCA)",
        "email": "info@odoo-community.org",
        "description": "The Odoo Community Association (OCA) is a non-profit organization, independent from the company Odoo SA, based in Switzerland that promotes open-source, collaborative development in the Odoo ERP software ecosystem. Our mission is to facilitate collaboration between Odoo developers and consultants throughout the ecosystem and ensure that Odoo remains a viable open source ERP. We do this, among others, by harbouring a large collection of open source code that is protected by a CLA, and hosting a yearly event.",
        "webpageUrl": {
            "url": "https://odoo-community.org"
        }
    },

    "projects": [{
        "guid": "openupgrade",
        "name": "OpenUpgrade project",
        "description": "OCA OpenUpgrade is a project for performing migrations between major versions of Odoo. It's a set of tools and scripts for performing major version migrations of Odoo Community instances, as an open-source alternative to Odoo's closed source migration path on https://upgrade.odoo.com/",
        "webpageUrl": {
            "url": "https://odoo-community.org/about/openupgrade"
        },
        "repositoryUrl": {
            "url": "https://github.com/OCA/OpenUpgrade",
            "wellKnown": "https://github.com/OCA/OpenUpgrade/blob/documentation/.well-known/funding-manifest-urls"
        },
        "licenses": ["spdx:AGPL-3.0-or-later"],
        "tags": ["developer-tools","database","erp","python","migration","odoo","data-migration"]
    }],

